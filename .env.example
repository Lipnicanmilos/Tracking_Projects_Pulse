# Skopíruj tento súbor ako .env a vyplň skutočné hodnoty. .env sa necommituje.

# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Kľúč na šifrovanie polí (encrypted_model_fields)
# vygeneruješ: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# E-mail
EMAIL_HOST=localhost
EMAIL_PORT=25

# JIRA
JIRA_SERVER=
JIRA_EMAIL=
JIRA_API_TOKEN=

# SharePoint
SHAREPOINT_SITE_URL=
SHAREPOINT_USERNAME=
SHAREPOINT_PASSWORD=
SHAREPOINT_RELATIVE_URL=
